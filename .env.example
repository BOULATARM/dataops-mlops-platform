# ══════════════════════════════════════════════════════════════════════════════
#  mlops-dataops-platform — Variables d'environnement
#  Copier vers .env et adapter selon le contexte (Local ou Docker).
# ══════════════════════════════════════════════════════════════════════════════

# ── CONTEXTE LOCAL (execution directe Python) ─────────────────────────────────
# Chemins resolus relativement a la racine du projet mlops-dataops-platform/

# Donnees brutes Olist (depuis data-engineering-platform voisin)
DATA_PATH=../data-engineering-platform/data/raw

# Fichier DuckDB warehouse
DUCKDB_PATH=./warehouse/duckdb/olist.duckdb

# ── CONTEXTE DOCKER (docker/docker-compose.yml) ───────────────────────────────
# Les chemins ci-dessous correspondent aux points de montage des volumes.
# Decommenter et utiliser ces valeurs dans docker-compose.yml > environment.
#
# DATA_PATH=/data/raw
# DUCKDB_PATH=/data/duckdb/olist.duckdb

# ── MLflow ────────────────────────────────────────────────────────────────────
# Local : pointer vers le serveur MLflow local (doit tourner separement)
MLFLOW_TRACKING_URI=http://localhost:5100

# Docker : le service mlflow-server est accessible via son nom de service
# MLFLOW_TRACKING_URI=http://mlflow-server:5000

MLFLOW_EXPERIMENT_NAME=olist-satisfaction
MLFLOW_MODEL_NAME=SatisfactionClassifier
MLFLOW_MODEL_STAGE=Production

# ── FastAPI ───────────────────────────────────────────────────────────────────
FASTAPI_PORT=8100

# ── Dagster ───────────────────────────────────────────────────────────────────
DAGSTER_PORT=3100
DAGSTER_HOME=./.dagster

# ── MLflow server (Docker) ────────────────────────────────────────────────────
MLFLOW_PORT=5100
MLFLOW_ARTIFACT_ROOT=./ml/mlflow

# ── dlt ───────────────────────────────────────────────────────────────────────
DLT_BATCH_SIZE=10000
